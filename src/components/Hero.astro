---
import ThemeSwitcher from "./ThemeSwitcher.astro";
const repo = "https://github.com/daavidrgz/gtheme";
---

<section class="hero">
  <div class="wrap-wide hero-inner">
    <div class="hero-copy reveal">
      <span class="pill">
        <span class="dot"></span>
        <span>Written in Rust</span>
        <span class="psep">·</span>
        <span>MIT / Apache-2.0</span>
      </span>

      <h1 class="title">
        One command to<br class="brk" />
        reskin <span class="grad">everything.</span>
      </h1>

      <p class="lede">
        Terminal, status bar, editor, and wallpaper —
        <strong>repainted instantly, in sync</strong>. Gtheme is a blazingly
        fast dotfile &amp; global theme manager for *NIX. 350+ themes, one
        invocation.
      </p>

      <div class="cta">
        <a href="#install" class="btn btn-primary">
          <span class="cta-prompt">$</span> gtheme install
        </a>
        <a href={repo} class="btn btn-ghost">
          <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"></path>
          </svg>
          Star on GitHub
        </a>
      </div>
    </div>

    <!-- live desktop mockup: the panes repaint with the active theme,
         seams between them evoke the mid-reskin light-leak. -->
    <div class="stage reveal">
      <div class="window desktop" aria-hidden="true">
        <div class="window-bar">
          <span class="tl"></span><span class="tl"></span><span class="tl"></span>
          <span class="tt">gtheme — live desktop</span>
          <span class="statusline">
            <span class="sl-seg sl-mode">NORMAL</span>
            <span class="sl-seg">main</span>
            <span class="sl-seg sl-accent">42%</span>
          </span>
        </div>

        <div class="panes">
          <!-- neofetch -->
          <div class="pane pane-fetch">
            <pre class="logo">   /\
  /  \
 / /\ \
/ /  \ \
\ \__/ /
 \____/</pre>
            <ul class="fetch">
              <li><span class="k">os</span> Arch Linux x86_64</li>
              <li><span class="k">wm</span> Hyprland</li>
              <li><span class="k">shell</span> zsh 5.9</li>
              <li><span class="k">theme</span> <span class="v-accent">gtheme</span></li>
              <li><span class="k">pkgs</span> 1287</li>
            </ul>
            <div class="palette">
              <span style="background:var(--red)"></span>
              <span style="background:var(--orange)"></span>
              <span style="background:var(--yellow)"></span>
              <span style="background:var(--green)"></span>
              <span style="background:var(--cyan)"></span>
              <span style="background:var(--blue)"></span>
              <span style="background:var(--purple)"></span>
            </div>
          </div>

          <!-- code -->
          <div class="pane pane-code">
            <pre><code><span class="c-kw">use</span> gtheme::<span class="c-fn">&#123;apply, Theme&#125;</span>;

<span class="c-kw">fn</span> <span class="c-fn">main</span>() -&gt; <span class="c-ty">Result</span>&lt;()&gt; &#123;
  <span class="c-kw">let</span> t = <span class="c-ty">Theme</span>::from_name(<span class="c-str">"tokyonight"</span>);
  apply(&amp;t)?;
  <span class="c-cm">// 42 targets · 128ms</span>
  <span class="c-fn">Ok</span>(())
&#125;</code></pre>
          </div>

          <!-- now-playing / visualizer -->
          <div class="pane pane-viz">
            <div class="viz-head">▶ now playing</div>
            <div class="viz-track">Daft Punk — Contact</div>
            <div class="bars">
              {Array.from({ length: 14 }).map((_, i) => (
                <span style={`--i:${i}`}></span>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class="live-hint">
        <span class="arrow" aria-hidden="true">↓</span>
        This page <em>is</em> the demo — pick a palette, watch it repaint live.
      </div>
      <ThemeSwitcher />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(3rem, 7vw, 5.5rem);
    padding-bottom: clamp(3rem, 7vw, 5rem);
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: clamp(2.5rem, 5vw, 4rem);
  }
  .hero-copy {
    max-width: 46rem;
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 8px var(--green);
  }
  .psep {
    color: var(--fg-muted);
  }
  .title {
    font-size: clamp(2.7rem, 8vw, 5.5rem);
    margin-top: 1.6rem;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }
  .hero-copy .lede {
    margin-top: 1.6rem;
    max-width: 54ch;
  }
  .cta {
    display: flex;
    gap: 0.85rem;
    margin-top: 2.2rem;
    flex-wrap: wrap;
  }
  .cta-prompt {
    font-family: var(--font-mono);
    opacity: 0.7;
  }

  /* ---- desktop mockup ---- */
  .stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.4rem;
    width: 100%;
  }
  .desktop {
    width: 100%;
    max-width: var(--maxw-wide);
    position: relative;
  }
  /* signature seam light-leaks between panes */
  .desktop::after {
    content: "";
    position: absolute;
    inset: 44px 0 0;
    pointer-events: none;
    background:
      linear-gradient(90deg, transparent 33%, color-mix(in srgb, var(--accent) 22%, transparent) 33.3%, transparent 34%),
      linear-gradient(90deg, transparent 66%, color-mix(in srgb, var(--accent-2) 22%, transparent) 66.3%, transparent 67%);
    mix-blend-mode: screen;
    opacity: 0.7;
  }
  .statusline {
    margin-left: auto;
    display: flex;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
  }
  .sl-seg {
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
    background: var(--bg-elev);
    color: var(--fg-muted);
  }
  .sl-mode {
    background: var(--accent);
    color: var(--on-accent);
    font-weight: 700;
  }
  .sl-accent {
    color: var(--accent);
  }
  .panes {
    display: grid;
    grid-template-columns: 1fr 1.15fr 0.85fr;
    min-height: 300px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }
  .pane {
    padding: 1.1rem 1.2rem;
    border-right: 1px solid var(--border);
    overflow: hidden;
  }
  .pane:last-child {
    border-right: 0;
  }
  .pane-fetch .logo {
    margin: 0 0 0.7rem;
    color: var(--accent);
    font-size: 0.72rem;
    line-height: 1.1;
  }
  .fetch {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    color: var(--fg-dim);
  }
  .fetch .k {
    display: inline-block;
    width: 3.6rem;
    color: var(--accent-2);
  }
  .v-accent {
    color: var(--accent);
    font-weight: 700;
  }
  .palette {
    display: flex;
    gap: 4px;
    margin-top: 0.9rem;
  }
  .palette span {
    width: 16px;
    height: 16px;
    border-radius: 3px;
  }
  .pane-code pre {
    margin: 0;
    color: var(--fg-dim);
    line-height: 1.5;
    white-space: pre-wrap;
  }
  .c-kw { color: var(--purple); }
  .c-fn { color: var(--blue); }
  .c-ty { color: var(--cyan); }
  .c-str { color: var(--green); }
  .c-cm { color: var(--fg-muted); font-style: italic; }
  .pane-viz {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .viz-head { color: var(--green); }
  .viz-track { color: var(--fg); }
  .bars {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 120px;
    margin-top: auto;
  }
  .bars span {
    flex: 1;
    border-radius: 2px 2px 0 0;
    background: linear-gradient(var(--accent), var(--accent-2));
    animation: eq 1.1s ease-in-out infinite;
    animation-delay: calc(var(--i) * -0.09s);
    height: 30%;
  }
  @keyframes eq {
    0%, 100% { height: 22%; }
    50% { height: 90%; }
  }

  .live-hint {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--fg-muted);
    text-align: center;
  }
  .live-hint em {
    color: var(--fg-dim);
    font-style: italic;
  }
  .arrow {
    color: var(--accent);
    animation: bob 1.8s ease-in-out infinite;
  }
  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }

  @media (max-width: 860px) {
    .panes {
      grid-template-columns: 1fr;
    }
    .pane {
      border-right: 0;
      border-bottom: 1px solid var(--border);
    }
    .pane-viz { display: none; }
    .desktop::after { display: none; }
  }
  @media (max-width: 560px) {
    .brk { display: none; }
  }
</style>
