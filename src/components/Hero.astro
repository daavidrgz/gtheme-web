---
import CopyCommand from "./CopyCommand.astro";
import ThemeSwitcher from "./ThemeSwitcher.astro";
const repo = "https://github.com/daavidrgz/gtheme";
---

<section class="hero">
  <div class="wrap hero-inner">
    <span class="badge">
      <span class="dot"></span>
      <span>Written in Rust</span>
      <span class="sep">·</span>
      <span>MIT / Apache-2.0</span>
    </span>

    <h1 class="title">
      One command to <span class="grad">reskin</span><br class="brk" />
      your entire desktop.
    </h1>

    <p class="lede">
      Gtheme is a <strong>blazingly fast</strong> dotfile and global theme
      manager for *NIX. Switch between <strong>+350 themes</strong>, wallpapers,
      and full desktop configs — centralized, automated, plug&nbsp;n&nbsp;play.
    </p>

    <div class="cta">
      <a href="#install" class="btn btn-primary">Install gtheme</a>
      <a href={repo} class="btn btn-ghost">
        <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"
          ></path>
        </svg>
        GitHub
      </a>
    </div>

    <div class="live-hint">
      <span class="arrow" aria-hidden="true">↓</span>
      This page is themed by gtheme. Pick a palette — watch it repaint live.
    </div>

    <ThemeSwitcher />

    <figure class="demo">
      <div class="demo-bar">
        <span></span><span></span><span></span>
        <span class="demo-title">gtheme — live desktop reskin</span>
      </div>
      <img
        src="/gtheme.gif"
        alt="Gtheme switching desktop themes live in a terminal"
        loading="eager"
        decoding="async"
      />
    </figure>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(2.5rem, 7vw, 4.5rem);
    padding-bottom: clamp(2rem, 5vw, 3rem);
    text-align: center;
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--fg-dim);
    background: var(--bg-elev);
    border: 1px solid var(--border);
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
  }
  .sep {
    color: var(--fg-muted);
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 8px var(--green);
  }
  .title {
    font-size: clamp(2.4rem, 6.5vw, 4.2rem);
    margin-top: 1.4rem;
  }
  .lede {
    margin-top: 1.4rem;
    max-width: 58ch;
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    color: var(--fg-dim);
  }
  .lede strong {
    color: var(--fg);
    font-weight: 600;
  }
  .cta {
    display: flex;
    gap: 0.85rem;
    margin-top: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .live-hint {
    margin-top: 3rem;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--fg-muted);
  }
  .arrow {
    color: var(--accent);
    animation: bob 1.8s ease-in-out infinite;
  }
  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }
  .live-hint + :global(.switcher) {
    margin-top: 1rem;
  }
  .demo {
    margin: 3.5rem 0 0;
    width: 100%;
    max-width: 900px;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-elev);
    overflow: hidden;
    box-shadow: 0 30px 80px -30px rgba(0, 0, 0, 0.7);
  }
  .demo-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: var(--bg-elev-2);
    border-bottom: 1px solid var(--border);
  }
  .demo-bar > span:not(.demo-title) {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--fg-muted);
  }
  .demo-bar > span:nth-child(1) { background: var(--red); }
  .demo-bar > span:nth-child(2) { background: var(--yellow); }
  .demo-bar > span:nth-child(3) { background: var(--green); }
  .demo-title {
    margin-left: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--fg-muted);
  }
  .demo img {
    display: block;
    width: 100%;
    height: auto;
  }
  @media (max-width: 640px) {
    .brk { display: none; }
    .demo-title { display: none; }
  }
</style>
