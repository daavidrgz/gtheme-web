---
import CopyCommand from "./CopyCommand.astro";
const repo = "https://github.com/daavidrgz/gtheme";
---

<section class="section cta-band section--ruled" id="get-started">
  <!-- seam light-leaks echoing the hero -->
  <div class="leaks" aria-hidden="true"></div>
  <div class="wrap cta-inner reveal">
    <span class="eyebrow">get started</span>
    <h2 class="cta-title">
      One command to reskin <span class="grad">everything.</span>
    </h2>
    <p class="lede cta-sub">
      Free, open-source, and blazingly fast. Install Gtheme and make your
      desktop yours in under a minute.
    </p>

    <div class="cta-cmd">
      <CopyCommand command={`sh -c "$(curl -fsSL https://gtheme.dev/install.sh)"`} />
    </div>

    <div class="cta-actions">
      <a href={repo} class="btn btn-primary">
        <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"></path>
        </svg>
        Star on GitHub
      </a>
      <a href="/features" class="btn btn-ghost">Explore features</a>
    </div>
  </div>
</section>

<style>
  .cta-band {
    position: relative;
    overflow: hidden;
    text-align: center;
  }
  .leaks {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(90deg, transparent 20%, color-mix(in srgb, var(--accent) 30%, transparent) 20.2%, transparent 21%),
      linear-gradient(90deg, transparent 78%, color-mix(in srgb, var(--accent-2) 28%, transparent) 78.2%, transparent 79%);
    mix-blend-mode: screen;
    opacity: 0.6;
    mask-image: radial-gradient(80% 100% at 50% 50%, #000, transparent 75%);
  }
  .cta-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .cta-title {
    font-size: clamp(2.2rem, 6vw, 4rem);
    letter-spacing: -0.03em;
    margin-top: 1rem;
    text-wrap: balance;
  }
  .cta-sub {
    margin-top: 1.2rem;
    max-width: 52ch;
  }
  .cta-cmd {
    width: 100%;
    display: flex;
    justify-content: center;
    margin-top: 0.5rem;
  }
  .cta-cmd :global(.cmd) {
    margin-inline: auto;
  }
  .cta-actions {
    display: flex;
    gap: 0.85rem;
    margin-top: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }
</style>
