---
const { leftTitle = "Before", rightTitle = "After" } = Astro.props;
---

<div class="diff-grid">
  <div class="window code-win">
    <div class="window-bar">
      <span class="tl"></span><span class="tl"></span><span class="tl"></span>
      <span class="tt">{leftTitle}</span>
    </div>
    <pre class="code-body"><code><slot name="left" /></code></pre>
  </div>
  <div class="diff-arrow">→</div>
  <div class="window code-win win-accent">
    <div class="window-bar">
      <span class="tl"></span><span class="tl"></span><span class="tl"></span>
      <span class="tt">{rightTitle}</span>
    </div>
    <pre class="code-body"><code><slot name="right" /></code></pre>
  </div>
</div>

<style>
  .diff-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0.8rem;
    align-items: start;
    margin: 1.6rem 0;
  }
  .diff-arrow {
    font-size: 1.4rem;
    color: var(--acc);
    font-family: var(--font-mono);
    padding-top: 2rem;
    text-align: center;
  }
  .code-body {
    margin: 0;
    padding: 0.9rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.55;
    color: var(--fg-dim);
    overflow-x: auto;
    max-height: 320px;
    overflow-y: auto;
  }
  .win-accent .window-bar {
    border-bottom-color: var(--acc);
  }
  @media (max-width: 640px) {
    .diff-grid { grid-template-columns: 1fr; }
    .diff-arrow { transform: rotate(90deg); padding-top: 0; }
  }
</style>
