---
const repo = "https://github.com/daavidrgz/gtheme";
---

<header class="nav">
  <div class="wrap nav-inner">
    <a href="/" class="brand">
      <span class="brand-mark">G</span>
      <span class="brand-name">gtheme</span>
    </a>
    <nav class="nav-links">
      <a href="/features">Features</a>
      <a href="/blog">Blog</a>
      <a href="/#install">Install</a>
      <a href="https://github.com/daavidrgz/gtheme-desktops">Desktops</a>
      <a href={repo} class="nav-gh" aria-label="GitHub repository">
        <svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor" aria-hidden="true">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"
          ></path>
        </svg>
      </a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--fg);
    font-weight: 700;
  }
  .brand:hover {
    color: var(--fg);
  }
  .brand-mark {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 9px;
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--on-accent);
    background: var(--accent);
  }
  .brand-name {
    font-family: var(--font-mono);
    letter-spacing: -0.01em;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    font-size: 0.92rem;
    font-weight: 500;
  }
  .nav-links a {
    color: var(--fg-dim);
  }
  .nav-links a:hover {
    color: var(--fg);
  }
  .nav-gh {
    display: grid;
    place-items: center;
  }
  @media (max-width: 560px) {
    .nav-links a:not(.nav-gh) {
      display: none;
    }
  }
</style>
