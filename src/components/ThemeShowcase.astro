---
// Section 2 — the live switcher. These buttons share the global
// [data-set-theme] wiring in ThemeSwitcher.astro, so a click repaints the
// entire page, including the preview to the right.
const themes = [
  { id: "tokyonight", label: "Tokyo Night", note: "cool · balanced" },
  { id: "catppuccin", label: "Catppuccin", note: "soft · pastel" },
  { id: "gruvbox", label: "Gruvbox", note: "warm · retro" },
  { id: "dracula", label: "Dracula", note: "vivid · dark" },
  { id: "nord", label: "Nord", note: "arctic · muted" },
  { id: "rosepine", label: "Rosé Pine", note: "rosy · low-key" },
];
---

<section class="section section--ruled" id="themes">
  <div class="wrap-wide">
    <div class="section-head reveal">
      <span class="eyebrow">live theme switcher</span>
      <h2 class="h2">Select a theme. See <span class="grad">everything</span> change.</h2>
      <p class="lede">
        Every surface reads from one palette — terminal, bar, editor, prompt,
        wallpaper. That's the whole idea, and this page runs on it.
      </p>
    </div>

    <div class="showcase reveal">
      <ul class="theme-list" role="group" aria-label="Preview a theme">
        {
          themes.map((t) => (
            <li>
              <button class="row" type="button" data-set-theme={t.id}>
                <span class={`swatch swatch-${t.id}`} aria-hidden="true" />
                <span class="row-text">
                  <span class="row-name">{t.label}</span>
                  <span class="row-note">{t.note}</span>
                </span>
                <span class="row-check" aria-hidden="true">✓</span>
              </button>
            </li>
          ))
        }
      </ul>

      <!-- preview desktop: repaints via CSS custom properties -->
      <div class="window preview" aria-hidden="true">
        <div class="window-bar">
          <span class="tl"></span><span class="tl"></span><span class="tl"></span>
          <span class="tt">~/desktop</span>
        </div>
        <div class="preview-body">
          <div class="wallpaper">
            <div class="topbar">
              <span class="tb-item tb-active">1</span>
              <span class="tb-item">2</span>
              <span class="tb-item">3</span>
              <span class="tb-spacer"></span>
              <span class="tb-item">
                <span class="clock-dot"></span> 09:41
              </span>
            </div>
            <div class="apps">
              <div class="app app-term">
                <p><span class="p-user">david</span><span class="p-at">@</span><span class="p-host">arch</span> <span class="p-path">~</span></p>
                <p><span class="p-prompt">❯</span> gtheme theme apply</p>
                <p class="p-ok">✓ repainted 42 targets in 128ms</p>
              </div>
              <div class="app app-side">
                <div class="chip-row"><span class="cd" style="background:var(--red)"></span> src</div>
                <div class="chip-row"><span class="cd" style="background:var(--green)"></span> lib</div>
                <div class="chip-row"><span class="cd" style="background:var(--blue)"></span> theme.toml</div>
                <div class="mini-bars">
                  <span style="background:var(--purple)"></span>
                  <span style="background:var(--cyan)"></span>
                  <span style="background:var(--orange)"></span>
                  <span style="background:var(--green)"></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .showcase {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: stretch;
  }
  .theme-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .row {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.7rem 0.9rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--bg-elev);
    color: var(--fg-dim);
    cursor: pointer;
    text-align: left;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease,
      transform 0.12s ease;
  }
  .row:hover {
    transform: translateX(3px);
    border-color: var(--accent);
    color: var(--fg);
  }
  .row[aria-pressed="true"] {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, var(--bg-elev));
    color: var(--fg);
  }
  .swatch {
    flex-shrink: 0;
    width: 34px;
    height: 20px;
    border-radius: 5px;
    background: linear-gradient(
      90deg,
      var(--s1) 0 33%,
      var(--s2) 33% 66%,
      var(--s3) 66% 100%
    );
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
  }
  .row-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }
  .row-name {
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
  .row-note {
    font-size: 0.72rem;
    color: var(--fg-muted);
  }
  .row-check {
    margin-left: auto;
    color: var(--accent);
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .row[aria-pressed="true"] .row-check {
    opacity: 1;
  }

  .swatch-tokyonight { --s1:#7aa2f7; --s2:#bb9af7; --s3:#9ece6a; }
  .swatch-catppuccin { --s1:#89b4fa; --s2:#cba6f7; --s3:#a6e3a1; }
  .swatch-gruvbox    { --s1:#fe8019; --s2:#fabd2f; --s3:#b8bb26; }
  .swatch-dracula    { --s1:#bd93f9; --s2:#ff79c6; --s3:#50fa7b; }
  .swatch-nord       { --s1:#81a1c1; --s2:#88c0d0; --s3:#a3be8c; }
  .swatch-rosepine   { --s1:#c4a7e7; --s2:#ebbcba; --s3:#9ccfd8; }

  /* ---- preview desktop ---- */
  .preview-body {
    padding: 1rem;
    background: var(--bg-elev-2);
  }
  .wallpaper {
    border-radius: var(--radius-sm);
    padding: 0.8rem;
    min-height: 320px;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    background:
      radial-gradient(120% 80% at 100% 0%, color-mix(in srgb, var(--accent) 30%, transparent), transparent 60%),
      radial-gradient(120% 90% at 0% 100%, color-mix(in srgb, var(--accent-2) 26%, transparent), transparent 55%),
      var(--bg);
    border: 1px solid var(--border);
  }
  .topbar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }
  .tb-item {
    padding: 0.15rem 0.55rem;
    border-radius: 5px;
    background: color-mix(in srgb, var(--bg-elev) 70%, transparent);
    color: var(--fg-dim);
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .tb-active {
    background: var(--accent);
    color: var(--on-accent);
    font-weight: 700;
  }
  .tb-spacer { flex: 1; }
  .clock-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green);
  }
  .apps {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 0.7rem;
    flex: 1;
  }
  .app {
    background: color-mix(in srgb, var(--bg-elev) 88%, transparent);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    backdrop-filter: blur(2px);
  }
  .app-term p { margin: 0 0 0.25rem; color: var(--fg-dim); }
  .p-user { color: var(--green); }
  .p-at { color: var(--fg-muted); }
  .p-host { color: var(--blue); }
  .p-path { color: var(--cyan); }
  .p-prompt { color: var(--accent); }
  .p-ok { color: var(--green); }
  .app-side { display: flex; flex-direction: column; gap: 0.45rem; }
  .chip-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--fg-dim);
  }
  .cd { width: 9px; height: 9px; border-radius: 2px; }
  .mini-bars {
    display: flex;
    align-items: flex-end;
    gap: 4px;
    height: 46px;
    margin-top: auto;
  }
  .mini-bars span {
    flex: 1;
    border-radius: 2px 2px 0 0;
  }
  .mini-bars span:nth-child(1) { height: 60%; }
  .mini-bars span:nth-child(2) { height: 100%; }
  .mini-bars span:nth-child(3) { height: 40%; }
  .mini-bars span:nth-child(4) { height: 78%; }

  @media (max-width: 820px) {
    .showcase {
      grid-template-columns: 1fr;
    }
    .theme-list {
      flex-direction: row;
      flex-wrap: wrap;
    }
    .theme-list li { flex: 1 1 45%; }
  }
</style>
