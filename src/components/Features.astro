---
const features = [
  {
    icon: "swatches",
    title: "+350 themes & wallpapers",
    body: "A huge curated palette library. Every color, everywhere, changes at once — terminal, bar, editor, wallpaper.",
    span: "big",
    accent: "purple",
  },
  {
    icon: "bolt",
    title: "One command",
    body: "Swap your entire desktop — apps, colors, wallpaper — with a single invocation.",
    accent: "yellow",
  },
  {
    icon: "hub",
    title: "Centralized & automated",
    body: "Define theming once. Gtheme propagates it across every app, consistently.",
    accent: "cyan",
  },
  {
    icon: "template",
    title: "Pattern templating",
    body: "Write config patterns with generic attributes; Gtheme fills them per theme. No manual editing.",
    accent: "green",
  },
  {
    icon: "package",
    title: "Plug 'n' play desktops",
    body: "Install ready-made desktop configs from other people and everything just works.",
    accent: "orange",
    span: "wide",
  },
];

const icons: Record<string, string> = {
  swatches:
    '<path d="M4 4h6v6H4zM14 4h6v6h-6zM4 14h6v6H4zM14 14h6v6h-6z"/>',
  bolt: '<path d="M13 2 3 14h7l-1 8 10-12h-7z"/>',
  hub: '<circle cx="12" cy="12" r="3"/><circle cx="12" cy="4" r="2"/><circle cx="12" cy="20" r="2"/><circle cx="4" cy="8" r="2"/><circle cx="20" cy="8" r="2"/><circle cx="4" cy="16" r="2"/><circle cx="20" cy="16" r="2"/>',
  template:
    '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 9v12"/>',
  package:
    '<path d="M12 2 3 7v10l9 5 9-5V7z"/><path d="M3 7l9 5 9-5M12 12v10"/>',
};
---

<section class="section" id="features">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">what it does</span>
      <h2 class="h2">Your ricing, standardized and automated.</h2>
    </div>

    <div class="bento">
      {
        features.map((f) => (
          <article class={`card ${f.span ?? ""}`} data-accent={f.accent}>
            <span class="ic">
              <svg
                viewBox="0 0 24 24"
                width="22"
                height="22"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={icons[f.icon]}
              />
            </span>
            <h3 class="card-title">{f.title}</h3>
            <p class="card-body">{f.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .bento {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1rem;
  }
  .card {
    grid-column: span 2;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.6rem;
    position: relative;
    overflow: hidden;
  }
  .card::after {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: var(--acc);
    opacity: 0.8;
  }
  .card.big {
    grid-column: span 3;
  }
  .card.wide {
    grid-column: span 3;
  }
  .card[data-accent="purple"] { --acc: var(--purple); }
  .card[data-accent="yellow"] { --acc: var(--yellow); }
  .card[data-accent="cyan"] { --acc: var(--cyan); }
  .card[data-accent="green"] { --acc: var(--green); }
  .card[data-accent="orange"] { --acc: var(--orange); }
  .ic {
    display: inline-grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 10px;
    color: var(--acc);
    background: color-mix(in srgb, var(--acc) 14%, transparent);
    margin-bottom: 1rem;
  }
  .card-title {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
  }
  .card.big .card-title {
    font-size: 1.5rem;
  }
  .card-body {
    color: var(--fg-dim);
    font-size: 0.95rem;
  }
  @media (max-width: 860px) {
    .bento {
      grid-template-columns: repeat(2, 1fr);
    }
    .card,
    .card.big,
    .card.wide {
      grid-column: span 2;
    }
  }
</style>
