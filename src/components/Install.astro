---
const steps = [
  {
    n: "1",
    title: "Clone the repo",
    lines: [
      "$ git clone --depth 1 \\",
      "    https://github.com/daavidrgz/gtheme.git",
      "$ cd gtheme",
    ],
  },
  {
    n: "2",
    title: "Run the installer",
    lines: ["$ ./install.sh", "✓ gtheme installed to ~/.local/bin"],
  },
  {
    n: "3",
    title: "Apply a desktop & theme",
    lines: [
      "$ gtheme desktop apply hyprland \\",
      "    --theme tokyonight",
      "✓ repainted 42 targets in 128ms",
    ],
  },
];
---

<section class="section section--ruled" id="install">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow">how it works</span>
      <h2 class="h2">Up and running in three steps.</h2>
      <p class="lede">
        Clone, install, apply. No package to publish to, no daemon to babysit —
        just your dotfiles and one binary.
      </p>
    </div>

    <ol class="steps reveal">
      {
        steps.map((s) => (
          <li class="step">
            <div class="step-head">
              <span class="num">{s.n}</span>
              <h3 class="step-title">{s.title}</h3>
            </div>
            <div class="window term">
              <div class="window-bar">
                <span class="tl" /><span class="tl" /><span class="tl" />
                <span class="tt">zsh</span>
              </div>
              <pre class="term-body"><code>{s.lines.map((l) => (
                <span class:list={["cl", { ok: l.startsWith("✓") }]}>{l}</span>
              ))}</code></pre>
            </div>
          </li>
        ))
      }
    </ol>

    <p class="docs-line reveal">
      Prefer to read first?
      <a href="https://github.com/daavidrgz/gtheme">Browse the docs →</a>
    </p>
  </div>
</section>

<style>
  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    counter-reset: step;
  }
  .step {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
  }
  /* connector arrows between steps on wide screens */
  .step:not(:last-child)::after {
    content: "→";
    position: absolute;
    top: 4px;
    right: -1.05rem;
    color: var(--fg-muted);
    font-family: var(--font-mono);
  }
  .step-head {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .num {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, var(--bg-elev));
    border: 1px solid var(--border);
  }
  .step-title {
    font-size: 1.1rem;
  }
  .term-body {
    margin: 0;
    padding: 1.1rem 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--fg-dim);
    overflow-x: auto;
    min-height: 7.5rem;
  }
  .term-body .cl { display: block; }
  .term-body .ok {
    color: var(--green);
  }
  .docs-line {
    margin-top: 2.5rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--fg-muted);
  }
  @media (max-width: 820px) {
    .steps {
      grid-template-columns: 1fr;
    }
    .step:not(:last-child)::after {
      content: "↓";
      top: auto;
      bottom: -1.15rem;
      right: auto;
      left: 12px;
    }
  }
</style>
