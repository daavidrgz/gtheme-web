---
import CopyCommand from "./CopyCommand.astro";
---

<section class="section" id="install">
  <div class="wrap install-grid">
    <div class="install-head">
      <span class="eyebrow">get started</span>
      <h2 class="h2">Up and running in three steps.</h2>
      <p class="install-sub">
        Clone the repo, run the installer, follow the initial setup. That's it.
      </p>
      <a href="https://github.com/daavidrgz/gtheme" class="btn btn-ghost">
        Read the docs
      </a>
    </div>

    <ol class="steps">
      <li class="step">
        <span class="num">1</span>
        <div class="step-body">
          <h3 class="step-title">Clone Gtheme</h3>
          <CopyCommand
            command="git clone --depth 1 https://github.com/daavidrgz/gtheme.git gtheme"
          />
        </div>
      </li>
      <li class="step">
        <span class="num">2</span>
        <div class="step-body">
          <h3 class="step-title">Run the installer</h3>
          <CopyCommand command="cd gtheme && ./install.sh" />
        </div>
      </li>
      <li class="step">
        <span class="num">3</span>
        <div class="step-body">
          <h3 class="step-title">Apply a desktop & theme</h3>
          <CopyCommand command="gtheme desktop apply <name>" />
        </div>
      </li>
    </ol>
  </div>
</section>

<style>
  .install-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 3rem;
    align-items: start;
  }
  .install-head {
    position: sticky;
    top: 90px;
  }
  .install-sub {
    margin: 1rem 0 1.6rem;
    color: var(--fg-dim);
    max-width: 40ch;
  }
  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .step {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .num {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--accent);
    background: var(--bg-elev);
    border: 1px solid var(--border);
    margin-top: 0.15rem;
  }
  .step-body {
    flex: 1;
    min-width: 0;
  }
  .step-title {
    font-size: 1.05rem;
    margin-bottom: 0.1rem;
  }
  .step-body :global(.cmd) {
    margin-top: 0.7rem;
  }
  @media (max-width: 820px) {
    .install-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .install-head {
      position: static;
    }
  }
</style>
