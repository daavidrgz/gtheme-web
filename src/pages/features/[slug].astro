---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { features } from "../../data/features";

export function getStaticPaths() {
  return features.map((f, i) => ({
    params: { slug: f.slug },
    props: {
      feature: f,
      prev: features[(i - 1 + features.length) % features.length],
      next: features[(i + 1) % features.length],
    },
  }));
}

const { feature, prev, next } = Astro.props;
---

<Layout
  title={`${feature.title} — Gtheme`}
  description={feature.tagline}
>
  <Nav />
  <main class="feat-page" data-accent={feature.accent}>
    <section class="section page-hero">
      <div class="wrap reveal">
        <a class="crumb" href="/features">← All features</a>
        <span class="ic">
          <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={feature.icon} />
        </span>
        <h1 class="page-title">{feature.title}</h1>
        <p class="lede">{feature.tagline}</p>
      </div>
    </section>

    <div class="wrap blocks">
      {
        feature.blocks.map((b) => (
          <article class="block reveal">
            <h2 class="block-h">{b.heading}</h2>
            <p class="block-body">{b.body}</p>
            {b.bullets && (
              <ul class="block-bullets">
                {b.bullets.map((x) => (
                  <li>{x}</li>
                ))}
              </ul>
            )}
            {b.code && (
              <div class="window code-win">
                <div class="window-bar">
                  <span class="tl" /><span class="tl" /><span class="tl" />
                  <span class="tt">{b.code.title ?? b.code.lang}</span>
                </div>
                <pre class="code-body"><code>{b.code.lines.map((l) => (
                  <span class:list={["cl", { ok: l.startsWith("✓") }]}>{l}</span>
                ))}</code></pre>
              </div>
            )}
          </article>
        ))
      }
    </div>

    <nav class="feat-nav wrap">
      <a class="fn fn-prev" href={`/features/${prev.slug}`}>
        <span class="fn-dir">← Previous</span>
        <span class="fn-title">{prev.title}</span>
      </a>
      <a class="fn fn-next" href={`/features/${next.slug}`}>
        <span class="fn-dir">Next →</span>
        <span class="fn-title">{next.title}</span>
      </a>
    </nav>

    <section class="section">
      <div class="wrap end-cta reveal">
        <h2 class="h2">Try it in one command.</h2>
        <a href="/#install" class="btn btn-primary">
          <span class="cta-prompt">$</span> gtheme install
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .feat-page {
    --acc: var(--accent);
  }
  .feat-page[data-accent="purple"] { --acc: var(--purple); }
  .feat-page[data-accent="yellow"] { --acc: var(--yellow); }
  .feat-page[data-accent="cyan"]   { --acc: var(--cyan); }
  .feat-page[data-accent="green"]  { --acc: var(--green); }
  .feat-page[data-accent="orange"] { --acc: var(--orange); }
  .feat-page[data-accent="blue"]   { --acc: var(--blue); }

  .crumb {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--fg-muted);
  }
  .page-hero .ic {
    display: grid;
    place-items: center;
    width: 56px;
    height: 56px;
    border-radius: 14px;
    margin: 1.4rem 0 0.4rem;
    color: var(--acc);
    background: color-mix(in srgb, var(--acc) 14%, transparent);
  }
  .page-title {
    font-size: clamp(2.4rem, 6vw, 3.6rem);
    letter-spacing: -0.03em;
    margin: 0.8rem 0 1.2rem;
    text-wrap: balance;
  }
  .page-hero .lede {
    max-width: 54ch;
  }

  .blocks {
    display: flex;
    flex-direction: column;
    gap: clamp(2.5rem, 5vw, 4rem);
    padding-top: 1rem;
  }
  .block {
    max-width: 68ch;
  }
  .block-h {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    margin-bottom: 0.8rem;
  }
  .block-h::before {
    content: "";
    display: inline-block;
    width: 26px;
    height: 3px;
    border-radius: 2px;
    background: var(--acc);
    margin-right: 0.7rem;
    vertical-align: middle;
  }
  .block-body {
    color: var(--fg-dim);
    font-size: 1.05rem;
    line-height: 1.7;
  }
  .block-bullets {
    margin: 1.1rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .block-bullets li {
    position: relative;
    padding-left: 1.6rem;
    color: var(--fg-dim);
  }
  .block-bullets li::before {
    content: "▸";
    position: absolute;
    left: 0;
    color: var(--acc);
  }
  .code-win {
    margin-top: 1.4rem;
    max-width: 640px;
  }
  .code-body {
    margin: 0;
    padding: 1.1rem 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--fg-dim);
    overflow-x: auto;
  }
  .code-body .cl { display: block; }
  .code-body .ok { color: var(--green); }

  .feat-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: clamp(3rem, 6vw, 5rem);
  }
  .fn {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1.2rem 1.4rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-elev);
    color: inherit;
    transition: border-color 0.2s ease;
  }
  .fn:hover { border-color: var(--acc); color: inherit; }
  .fn-next { text-align: right; }
  .fn-dir {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--fg-muted);
  }
  .fn-title {
    font-family: var(--font-display);
    font-weight: 600;
  }
  .end-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.4rem;
    text-align: center;
  }
  .cta-prompt { font-family: var(--font-mono); opacity: 0.7; }
  @media (max-width: 560px) {
    .feat-nav { grid-template-columns: 1fr; }
    .fn-next { text-align: left; }
  }
</style>
